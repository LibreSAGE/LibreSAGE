{
  "name": "rts",
  "dependencies": [
    "ffmpeg",
    "fontconfig",
    "freetype",
    "glm",
    "glslang",
    "gtest",
    {
      "name": "sdl3",
      "default-features": false,
      "features": [
        "vulkan",
        "wayland",
        "x11"
      ],
      "platform": "linux"
    },
    {
      "name": "sdl3",
      "features": [
        "vulkan"
      ],
      "platform": "!linux"
    },
    "sdl3-image",
    "sdl3-net",
    "zlib",
    {
      "name": "dxvk",
      "default-features": false,
      "features": [
        "d3d8",
        "d3d9",
        "sdl3"
      ]
    },
    "icu",
    "miniaudio",
    "lzo"
  ]
}
